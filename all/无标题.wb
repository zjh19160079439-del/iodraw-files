{"type":"wb","version":2,"source":"https://www.iodraw.com","elements":[{"id":"A88MapHYuuIXOKw5SkrJK","type":"rectangle","x":422.66668701171875,"y":426.00001525878906,"width":568.6666870117188,"height":459.9999847412109,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":922077863,"version":169,"versionNonce":553819207,"isDeleted":false,"boundElements":null,"updated":1779172332065,"link":null},{"id":"pQQ1ujcoZnefujvXs_pOI","type":"text","x":466.66668701171875,"y":464.3333435058594,"width":21,"height":272,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":1969545353,"version":44,"versionNonce":761538087,"isDeleted":false,"boundElements":null,"updated":1779172402978,"link":null,"text":"x1\n\nx2\n\nx3\n\nx4\n\nx5\n\nx6\n","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":267,"containerId":null,"originalText":"x1\n\nx2\n\nx3\n\nx4\n\nx5\n\nx6\n"},{"id":"wz0wRSfaW8WDnkjDv7gWC","type":"arrow","x":530,"y":580.0000305175781,"width":45.33331298828125,"height":0,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"round","seed":640326057,"version":61,"versionNonce":1636686825,"isDeleted":false,"boundElements":null,"updated":1779172440357,"link":null,"points":[[0,0],[45.33331298828125,0]],"lastCommittedPoint":null,"startBinding":null,"endBinding":null,"startArrowhead":null,"endArrowhead":"arrow"},{"id":"pIOQYVwQASCvt4lZUja8g","type":"text","x":616.6666870117188,"y":467.66668701171875,"width":22,"height":249,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":733803303,"version":24,"versionNonce":1925932649,"isDeleted":false,"boundElements":null,"updated":1779172463377,"link":null,"text":"x1\n\nx4\n\nx2\n\nx5\n\nx3\n\nx6","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":245,"containerId":null,"originalText":"x1\n\nx4\n\nx2\n\nx5\n\nx3\n\nx6"},{"type":"text","version":66,"versionNonce":1384793767,"isDeleted":false,"id":"gH8mRjGQsJq_a7WrnoFv2","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":825.6666259765625,"y":474.1667175292969,"strokeColor":"#000000","backgroundColor":"transparent","width":22,"height":249,"seed":2112464905,"groupIds":[],"strokeSharpness":"sharp","boundElements":[],"updated":1779172484737,"link":null,"fontSize":20,"fontFamily":2,"text":"x1\n\nx4\n\nx2\n\nx5\n\nx3\n\nx6","baseline":245,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"x1\n\nx4\n\nx2\n\nx5\n\nx3\n\nx6"},{"id":"bWyBbsl9ljMtolg_tTnzz","type":"text","x":659.3333129882812,"y":575.0000305175781,"width":11,"height":23,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":1022347817,"version":3,"versionNonce":514235657,"isDeleted":false,"boundElements":null,"updated":1779172489430,"link":null,"text":"x","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":18,"containerId":null,"originalText":"x"},{"id":"swKPc_z_muqNiBkpAIULk","type":"text","x":698.6666870117188,"y":469.66668701171875,"width":32,"height":23,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":197137385,"version":5,"versionNonce":181988777,"isDeleted":false,"boundElements":null,"updated":1779172495240,"link":null,"text":"cos","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":18,"containerId":null,"originalText":"cos"},{"id":"A4fB4Jz4IinftjFQUya8n","type":"text","x":478.66668701171875,"y":761.0000305175781,"width":790,"height":755,"angle":0,"strokeColor":"#000000","backgroundColor":"transparent","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"strokeSharpness":"sharp","seed":1572134247,"version":3,"versionNonce":1310890119,"isDeleted":false,"boundElements":null,"updated":1779173011544,"link":null,"text":"[原始输入向量] \n  q = [q_0, q_1, q_2, q_3]\n       │\n       ├─────────────────────────────────────────┐\n       │                                         │\n▼ 步骤 1：生成角度向量 (针对位置 m)              ▼ 步骤 2：构造“半旋转”向量 (rotate_half)\n根据维度频率生成角度向量 θ                       将相邻奇偶位交换，并将前半部分取反\n(通常相邻两位使用相同的频率)                     \n  Θ = [mθ_0, mθ_0, mθ_1, mθ_1]                  q_rotated = [-q_1, q_0, -q_3, q_2]\n       │                                         │\n       │                                         │\n▼ 步骤 3：计算 Cos 和 Sin 缓存                   │\n  cos_Θ = [cos(mθ_0), cos(mθ_0), ...]            │\n  sin_Θ = [sin(mθ_0), sin(mθ_0), ...]            │\n       │                                         │\n       │                                         │\n       ├─────────────────┐                       ├─────────────────┐\n       │                 │                       │                 │\n▼ 步骤 4：原向量与 Cos 相乘                    ▼ 步骤 5：旋转向量与 Sin 相乘\n(逐元素 Hadamard 积 ⊙)                         (逐元素 Hadamard 积 ⊙)\n  A = q ⊙ cos_Θ                                  B = q_rotated ⊙ sin_Θ\n       │                                         │\n       └─────────────────┬───────────────────────┘\n                         │\n▼ 步骤 6：最终结果相加 (A + B)\n  q_out = [\n    q_0*cos(mθ_0) - q_1*sin(mθ_0),   // 维度 0 (新的 q_0)\n    q_1*cos(mθ_0) + q_0*sin(mθ_0),   // 维度 1 (新的 q_1)\n    q_2*cos(mθ_1) - q_3*sin(mθ_1),   // 维度 2 (新的 q_2)\n    q_3*cos(mθ_1) + q_2*sin(mθ_1)    // 维度 3 (新的 q_3)\n  ]","fontSize":20,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":750,"containerId":null,"originalText":"[原始输入向量] \n  q = [q_0, q_1, q_2, q_3]\n       │\n       ├─────────────────────────────────────────┐\n       │                                         │\n▼ 步骤 1：生成角度向量 (针对位置 m)              ▼ 步骤 2：构造“半旋转”向量 (rotate_half)\n根据维度频率生成角度向量 θ                       将相邻奇偶位交换，并将前半部分取反\n(通常相邻两位使用相同的频率)                     \n  Θ = [mθ_0, mθ_0, mθ_1, mθ_1]                  q_rotated = [-q_1, q_0, -q_3, q_2]\n       │                                         │\n       │                                         │\n▼ 步骤 3：计算 Cos 和 Sin 缓存                   │\n  cos_Θ = [cos(mθ_0), cos(mθ_0), ...]            │\n  sin_Θ = [sin(mθ_0), sin(mθ_0), ...]            │\n       │                                         │\n       │                                         │\n       ├─────────────────┐                       ├─────────────────┐\n       │                 │                       │                 │\n▼ 步骤 4：原向量与 Cos 相乘                    ▼ 步骤 5：旋转向量与 Sin 相乘\n(逐元素 Hadamard 积 ⊙)                         (逐元素 Hadamard 积 ⊙)\n  A = q ⊙ cos_Θ                                  B = q_rotated ⊙ sin_Θ\n       │                                         │\n       └─────────────────┬───────────────────────┘\n                         │\n▼ 步骤 6：最终结果相加 (A + B)\n  q_out = [\n    q_0*cos(mθ_0) - q_1*sin(mθ_0),   // 维度 0 (新的 q_0)\n    q_1*cos(mθ_0) + q_0*sin(mθ_0),   // 维度 1 (新的 q_1)\n    q_2*cos(mθ_1) - q_3*sin(mθ_1),   // 维度 2 (新的 q_2)\n    q_3*cos(mθ_1) + q_2*sin(mθ_1)    // 维度 3 (新的 q_3)\n  ]"}],"appState":{"theme":"light","currentChartType":"bar","currentItemBackgroundColor":"transparent","currentItemEndArrowhead":"arrow","currentItemFillStyle":"hachure","currentItemFontFamily":2,"currentItemFontSize":20,"currentItemLinearStrokeSharpness":"round","currentItemOpacity":100,"currentItemRoughness":1,"currentItemStartArrowhead":null,"currentItemStrokeColor":"#000000","currentItemStrokeSharpness":"sharp","currentItemStrokeStyle":"solid","currentItemStrokeWidth":1,"currentItemTextAlign":"left","cursorButton":"down","editingGroupId":null,"elementLocked":false,"elementType":"selection","exportBackground":true,"exportScale":1,"exportEmbedScene":false,"exportWithDarkMode":false,"gridSize":null,"lastPointerDownWith":"mouse","name":"Untitled-2026-05-19-1431","openMenu":null,"previousSelectedElementIds":{},"scrolledOutside":false,"scrollX":164.66668701171875,"scrollY":-101.33334350585938,"selectedElementIds":{},"selectedGroupIds":{},"shouldCacheIgnoreZoom":false,"showStats":false,"viewBackgroundColor":"#ffffff","zenModeEnabled":false,"zoom":{"value":1}},"files":{}}